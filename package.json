'use strict';
const express = require('express');
const db      = require('../db');
const { requireAuth } = require('../middleware/auth');
const router  = express.Router();

// GET /api/customers?q=search
router.get('/', requireAuth, async function(req, res) {
  try {
    const q = req.query.q ? '%' + req.query.q + '%' : '%';
    const r = await db.query(
      `SELECT c.*, COUNT(qu.id) as quote_count
       FROM customers c
       LEFT JOIN quotes qu ON qu.customer_id = c.id
       WHERE c.name ILIKE $1 OR c.email ILIKE $1 OR c.contact ILIKE $1
       GROUP BY c.id ORDER BY c.name LIMIT 50`,
      [q]
    );
    res.json(r.rows);
  } catch(e) { res.status(500).json({ error: e.message }); }
});

// GET /api/customers/:id
router.get('/:id', requireAuth, async function(req, res) {
  try {
    const c = await db.query('SELECT * FROM customers WHERE id=$1', [req.params.id]);
    if (!c.rows.length) return res.status(404).json({ error: 'Not found' });
    const q = await db.query(
      `SELECT q.id,q.quote_number,q.status,q.created_at,e.name as employee_name
       FROM quotes q LEFT JOIN employees e ON e.id=q.employee_id
       WHERE q.customer_id=$1 ORDER BY q.created_at DESC LIMIT 20`,
      [req.params.id]
    );
    res.json({ ...c.rows[0], quotes: q.rows });
  } catch(e) { res.status(500).json({ error: e.message }); }
});

// POST /api/customers
router.post('/', requireAuth, async function(req, res) {
  try {
    const { name, contact, email, phone, notes } = req.body;
    if (!name) return res.status(400).json({ error: 'Name required' });
    const r = await db.query(
      'INSERT INTO customers (name,contact,email,phone,notes) VALUES ($1,$2,$3,$4,$5) RETURNING *',
      [name, contact||null, email||null, phone||null, notes||null]
    );
    res.json(r.rows[0]);
  } catch(e) { res.status(500).json({ error: e.message }); }
});

// PUT /api/customers/:id
router.put('/:id', requireAuth, async function(req, res) {
  try {
    const { name, contact, email, phone, notes } = req.body;
    const r = await db.query(
      'UPDATE customers SET name=$1,contact=$2,email=$3,phone=$4,notes=$5 WHERE id=$6 RETURNING *',
      [name, contact||null, email||null, phone||null, notes||null, req.params.id]
    );
    res.json(r.rows[0]);
  } catch(e) { res.status(500).json({ error: e.message }); }
});

module.exports = router;
